{
  "name": "electron-squirrel-test",
  "version": "2.0.12",
  "main": "electron/main.js",
  "description": "Testing Squirrel Auto-Updater",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "release": "electron-builder -p always"
  },
  "keywords": [],
  "author": "Dhruvit",
  "license": "ISC",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "loudness": "^0.4.2"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.dhruvit.squirreltest",
    "compression": "maximum",
    "files": [
      "**/*",
      "!release{,/**}",
      "!*.blockmap",
      "!builder-debug.yml",
      "!builder-effective-config.yaml"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DhruvitPatel007",
        "repo": "Electron-Update",
        "private": false,
        "timeout": 600000
      }
    ]
  }
}
